{
  "entities": {
    "Trip": {
      "title": "Trip",
      "description": "A travel itinerary generated by AI",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID who saved the trip" },
        "destination": { "type": "string" },
        "duration": { "type": "number" },
        "budget": { "type": "string" },
        "style": { "type": "string" },
        "totalEstimatedCost": { "type": "number" },
        "weatherPreview": { "type": "string" },
        "itinerary": { "type": "array", "description": "Serialized JSON of the itinerary" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "destination", "duration", "budget", "style", "totalEstimatedCost", "itinerary", "createdAt"]
    }
  },
  "firestore": {
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Saved travel plans"
    }
  }
}
